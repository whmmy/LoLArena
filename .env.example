# Copy to .env and fill in. Never commit .env.

# ---- PandaScore (LoL data, free tier) — legacy/fallback ----
# Get from https://developers.pandascore.co  (dashboard -> API keys)
# NOTE: the pipeline now uses Cito (below) as the primary data source.
# PandaScore is kept as a fallback client but not called by default.
PANDASCORE_API_KEY=
PANDASCORE_BASE_URL=https://api.pandascore.co

# ---- CitoApi (LoL data, primary source) ----
# Get from https://citoapi.com  (dashboard -> API keys). Key prefix: cito_live_…
# Free tier: 500 req/month per key, 10 req/min.
# Set CITO_API_KEYS (comma-separated) to pool multiple keys and multiply quota;
# the client auto-rotates and switches keys on rate-limit/quota errors.
# A single CITO_API_KEY also works for backward compatibility.
CITO_API_KEY=
CITO_API_KEYS=
CITO_BASE_URL=https://api.citoapi.com

# ---- web_search tool (unified backend for ALL models) ----
# Zhipu / Z.AI  web_search. Same key as the Zhipu chat API.
# https://bigmodel.cn/usercenter/proj-mgmt/apikeys
ZHIPU_WEBSEARCH_API_KEY=
ZHIPU_WEBSEARCH_BASE_URL=https://open.bigmodel.cn/api
ZHIPU_WEBSEARCH_ENGINE=search_pro

# ---- Frontier LLMs ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=

# ---- Open-weight / national models (mostly via OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Optional: route ALL models through one OpenAI-compatible proxy by setting
# LOLA_MODEL_PROXY to a single base_url. Leave blank to use each model's own base_url.
LOLA_MODEL_PROXY=

# ---- Scheduling ----
# How many hours before kickoff to run series-level prediction.
LOLA_PREDICT_LEAD_H=3
# Result fetch grace window, in hours after scheduled end.
LOLA_RESULT_GRACE_H=2

# ---- Server ----
LOLA_HOST=127.0.0.1
LOLA_PORT=8000
