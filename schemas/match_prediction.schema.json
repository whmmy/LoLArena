{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lolarena/match_prediction.schema.json",
  "title": "LoLArena Series (Match) Prediction",
  "description": "Output schema for a whole-series (Bo3/Bo5) LoL prediction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reasoning", "win_probs", "predicted_winner", "series_score",
    "series_length", "favored_side", "key_players", "swing_factors",
    "meta_style_signals", "sources"
  ],
  "properties": {
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "fundamentals", "matchups", "meta_style", "h2h_psych"],
      "properties": {
        "overall":       { "type": "string", "minLength": 40 },
        "fundamentals":  { "type": "string", "minLength": 120 },
        "matchups":      { "type": "string", "minLength": 150 },
        "meta_style":    { "type": "string", "minLength": 100 },
        "h2h_psych":     { "type": "string", "minLength": 80 }
      }
    },
    "win_probs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blue", "red"],
      "properties": {
        "blue": { "type": "number", "minimum": 0, "maximum": 1 },
        "red":  { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "predicted_winner": { "type": "string", "enum": ["blue", "red"] },
    "series_score": {
      "type": "string",
      "description": "Final series score, blue-red, e.g. '3-1'.",
      "pattern": "^\\d+-\\d+$"
    },
    "series_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7,
      "description": "Total games played; must equal sum of the two digits in series_score."
    },
    "favored_side": {
      "type": "string",
      "enum": ["blue_strong", "blue_slight", "even", "red_slight", "red_strong"]
    },
    "key_players": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["player", "team", "role", "reason"],
        "properties": {
          "player": { "type": "string", "minLength": 1 },
          "team":   { "type": "string", "enum": ["blue", "red"] },
          "role":   { "type": "string", "enum": ["top", "jun", "mid", "adc", "sup"] },
          "reason": { "type": "string", "minLength": 5 }
        }
      }
    },
    "swing_factors": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 5 }
    },
    "meta_style_signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 3 }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query", "accessed_at"],
        "properties": {
          "query": { "type": "string" },
          "accessed_at": { "type": "string" }
        }
      }
    }
  }
}
